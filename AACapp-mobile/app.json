{
  "expo": {
    "name": "AACapp-mobile",
    "slug": "AACapp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "AAC Beacon needs Bluetooth to scan and verify nearby BlueCharm beacons.",
        "NSBluetoothPeripheralUsageDescription": "AAC Beacon needs Bluetooth to scan and verify nearby BlueCharm beacons."
      },
      "bundleIdentifier": "com.dagt03.AACapp-mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
